#Задача 1: Составить функцию, которая выведет на экран строку, содержащую задаваемое с клавиатуры число символов.

def print_symbol_line():
    symbol = input("Введите символ: ")
    n = int(input("Введите число: "))
    
    i = 1
    while i <= n:
        print(symbol, end="")
        i += 1
    print()

print_symbol_line()
