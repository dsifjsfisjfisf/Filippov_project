#Дана строка, состоящая из русских слов, набранных заглавными буквами и разделенных пробелами (одним или несколькими). Найти количество слов, которые содержат ровно три буквы «А».
text = input("Введите строку: ")
words = text.split()
count = 0

for word in words:
    if word.count('А') == 3:
        count += 1

print(count)
