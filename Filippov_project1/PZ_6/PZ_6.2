#Дан целочисленный список A размера N. Переписать в новый целочисленный список B того же размера сначала все элементы исходного списка с чётными номерами, а затем — с нечётными: A2,A4,A6,...,A1,A3,A5,...
def task2():
    N = int(input("Введите количество элементов N: "))
    
    A = []
    for i in range(N):
        A.append(int(input(f"A[{i}] = ")))
    
    B = []
    
    for i in range(1, N, 2):
        B.append(A[i])
        
    for i in range(0, N, 2):
        B.append(A[i])
    
    print(f"Исходный список A: {A}")
    print(f"Результат B: {B}")

task2()
